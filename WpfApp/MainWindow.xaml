<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        Title="Auto Login"
        Height="450"
        Width="400"
        ResizeMode="NoResize">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 10">
            <Label>Made by Jayrock of Kronos</Label>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 10">
            <Label>Enter the whole path to Wow.exe</Label>
            <TextBox x:Name="WowPath" Width="200" Margin="0 0 5 0" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0 0 0 10">
            <Label>Delay (ms):</Label>
            <TextBlock x:Name="DelayValueText" Text="2500" />
            <Slider x:Name="DelaySlider" Minimum="0" Maximum="30000" Value="5000" TickFrequency="1000"
                IsSnapToTickEnabled="True" Width="350" ValueChanged="DelaySlider_ValueChanged"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 10">
            <Label>Username</Label>
            <TextBox x:Name="UsernameTextBox" Width="100" Margin="0 0 5 0" />
            <Label>Password</Label>
            <PasswordBox x:Name="PasswordTextBox" Width="100" Margin="0 0 5 0"/>
            <Button Content="Add" Click="AddAccount_Click"/>
        </StackPanel>


        <!-- Scrollable area -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ListView x:Name="AccountsListView" ItemsSource="{Binding Accounts}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Delete" Click="DeleteButton_Click" Tag="{Binding}" Margin="5 0"/>
                            <TextBlock Text="{Binding Username}" Width="100"/>
                            <Button Content="Run" Click="RunButton_Click" Tag="{Binding}" Margin="5 0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </DockPanel>

</Window>
